# Runtime database connection. Use the pooled Neon connection string for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
# Optional alias supported by the app if you prefer a Neon-specific name.
NEON_DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# Maintenance/migration connection. Use the direct Neon connection string.
NEON_DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
# Legacy alias also supported by scripts: NEON_DIRECT_DATABASE_URL.

# Optional Postgres.js pool tuning for runtime traffic.
POSTGRES_MAX_CONNECTIONS=3
POSTGRES_IDLE_TIMEOUT_SECONDS=20
POSTGRES_MAX_LIFETIME_SECONDS=600

# Auth/session secrets.
AUTH_SECRET="replace-me"
JWT_SECRET="replace-me"

# Optional OAuth providers.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_CLIENT_SECRET=""
APPLE_ID=""
APPLE_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Optional semantic query embedding service.
RECOMMENDER_ENGINE="semantic"
SEMANTIC_SEARCH_EMBEDDING_COLUMN="embedding_overall"
QUERY_EMBEDDING_PROVIDER="openai"
QUERY_EMBEDDING_MODEL="text-embedding-3-small"
QUERY_EMBEDDING_DIMENSIONS="384"
OPENAI_API_KEY=""

# Optional maintenance scripts.
TMDB_AUTH_TOKEN=""
